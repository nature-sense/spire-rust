{
  "name": "spire-rust",
  "displayName": "Spire Rust",
  "description": "AI-powered code analysis with a Rust MCP server core",
  "version": "0.1.0",
  "publisher": "naturesense",
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": [
    "Programming Languages",
    "Other"
  ],
  "activationEvents": [
    "onStartupFinished"
  ],
  "main": "./dist/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "spire.explainCode",
        "title": "Spire: Explain Code"
      },
      {
        "command": "spire.searchCodebase",
        "title": "Spire: Search Codebase"
      },
      {
        "command": "spire.analyzeCode",
        "title": "Spire: Analyze Code"
      },
      {
        "command": "spire.openChat",
        "title": "Spire: Open Chat"
      }
    ],
    "keybindings": [
      {
        "command": "spire.explainCode",
        "key": "ctrl+shift+e",
        "mac": "cmd+shift+e"
      },
      {
        "command": "spire.openChat",
        "key": "ctrl+shift+i",
        "mac": "cmd+shift+i"
      }
    ]
  },
  "scripts": {
    "compile": "tsc -p ./tsconfig.json",
    "watch": "tsc -watch -p ./tsconfig.json",
    "test": "node ./out/test/runTest.js"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "@types/vscode": "^1.90.0",
    "typescript": "^5.4.0"
  }
}
