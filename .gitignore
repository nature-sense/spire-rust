# Rust build artifacts (workspace-level)
target/

# Legacy per-crate target dirs (keep for backward compatibility)
spire-core/target/
mcp/*/target/

# Node.js dependencies (pnpm workspace hoisting)
node_modules/
spire-extension/node_modules/

# TypeScript compiled output
spire-extension/dist/

# SeleneDB Write-Ahead Log persistence files (runtime data)
*.wal

# Pre-compiled binaries (staged by scripts/stage-binaries.mjs)
spire-extension/bin/

# VS Code extension packages
*.vsix

# macOS
.DS_Store

# IDE/editor local settings (keep shared .vscode/*.json)
.vscode/settings.json
